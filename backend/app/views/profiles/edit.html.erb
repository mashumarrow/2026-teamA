<main class="min-h-screen bg-base-200 text-base-content">
  <section class="flex min-h-screen items-center justify-center px-5 py-10">
    <div class="grid w-full max-w-4xl overflow-hidden rounded-lg border border-base-300 bg-base-100 shadow-2xl md:grid-cols-[0.9fr_1.1fr]">
      <aside class="bg-base-300/40 p-8">
        <p class="mb-3 text-xs font-bold uppercase text-primary">First Setup</p>
        <h1 class="text-3xl font-bold leading-tight">研究室ポータルの初期設定</h1>
        <p class="mt-4 text-sm leading-7 text-base-content/70">
          入退室に使う IC カードの IDm だけ登録してください。
        </p>

        <ul class="steps steps-vertical mt-8">
          <li class="step step-primary">メール認証li>
          <li class="step step-primary">氏名を確認</li>
          <li class="step">ICカード登録</li>
        </ul>
      </aside>

      <div class="p-8">
        <% if alert.present? %>
          <div class="alert alert-error mb-5">
            <span><%= alert %></span>
          </div>
        <% end %>

        <%= form_with url: setup_path, method: :patch, scope: :profile, class: "space-y-5" do |form| %>
          <div class="form-control">
            <label class="label">
              <span class="label-text font-semibold">氏名</span>
              
            </label>
            <input type="text" value="<%= current_user.name %>" class="input input-bordered" disabled>
            
          </div>

          <div class="form-control">
            <%= form.label :idm, class: "label" do %>
              <span class="label-text font-semibold">ICカード IDm</span>
              <span class="badge badge-primary">Required</span>
            <% end %>
            <%= form.text_field :idm,
                  value: @felica_card&.idm,
                  class: "input input-bordered font-mono tracking-wide",
                  required: true,
                  placeholder: "0123456789ABCDEF",
                  pattern: "[0-9A-Fa-f]{8,32}",
                  autocomplete: "off",
                  inputmode: "text" %>
            <label class="label">
              <span class="label-text-alt">IDm を入力してください。</span>
            </label>
          </div>

          <div class="flex items-center justify-between gap-3 pt-3">
            <%= link_to "ログアウト", logout_path, class: "btn btn-ghost btn-sm" %>
            <%= form.submit "登録して始める", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
</main>

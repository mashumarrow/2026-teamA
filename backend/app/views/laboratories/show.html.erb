<style>
  .portal-shell { position: relative; min-height: 100vh; overflow: hidden; background: #101418; color: #f8fafc; }
  #canvas-3d { position: fixed; inset: 0; z-index: 0; width: 100vw; height: 100vh; }
  .portal-topbar, .portal-sidebar, .music-panel, .stay-panel, .card-panel, .queue-panel { position: fixed; z-index: 20; }
  .portal-topbar { top: 18px; left: 22px; right: 22px; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; pointer-events: none; }
  .portal-topbar .topbar-actions, .portal-topbar .dropdown { pointer-events: auto; }
  .portal-kicker { margin: 0; color: #7dd3fc; font-size: 12px; font-weight: 700; text-transform: uppercase; }
  .portal-topbar h1 { margin: 2px 0 0; font-size: clamp(22px, 3vw, 38px); letter-spacing: 0; }
  .portal-status { max-width: 320px; padding: 10px 14px; border: 1px solid rgba(255,255,255,.18); border-radius: 8px; font-size: 13px; text-align: right; backdrop-filter: blur(10px); }
  .portal-sidebar { left: 22px; bottom: 22px; display: grid; gap: 10px; width: min(280px, calc(100vw - 44px)); pointer-events: auto; }
  .portal-action { display: grid; gap: 4px; min-height: 62px; padding: 14px 16px; border: 1px solid rgba(255,255,255,.22); border-radius: 8px; color: #f8fafc; background: rgba(15,23,42,.88); text-align: left; cursor: default; box-shadow: 0 12px 34px rgba(0,0,0,.35); }
  .portal-action[data-open-music] { cursor: pointer; }
  .portal-action[data-open-music]:hover { border-color: rgba(147,197,253,.62); background: rgba(15,23,42,.96); }
  .portal-action[data-open-stay], .portal-action[data-open-card], .portal-action[data-open-queue] { cursor: pointer; }
  .portal-action[data-open-stay]:hover, .portal-action[data-open-card]:hover, .portal-action[data-open-queue]:hover { border-color: rgba(134,239,172,.62); background: rgba(15,23,42,.96); }
  .portal-action span { color: #93c5fd; font-size: 12px; font-weight: 700; text-transform: uppercase; }
  .music-panel, .stay-panel, .card-panel, .queue-panel { display: none; top: 50%; left: 50%; width: min(1040px, calc(100vw - 48px)); max-height: min(720px, calc(100vh - 48px)); overflow: auto; padding: 28px; border: 1px solid rgba(148,163,184,.35); border-radius: 8px; background: rgba(20,26,32,.94); box-shadow: 0 24px 80px rgba(0,0,0,.42); backdrop-filter: blur(12px); transform: translate(-50%, -50%); pointer-events: auto; }
  .music-panel.is-open, .stay-panel.is-open, .card-panel.is-open, .queue-panel.is-open { display: block; }
  .music-panel-header, .stay-panel-header, .card-panel-header, .queue-panel-header { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 16px; }
  .music-panel h2, .stay-panel h2, .card-panel h2, .queue-panel h2 { margin: 0 0 16px; font-size: 24px; }
  .music-panel-header h2, .stay-panel-header h2, .card-panel-header h2, .queue-panel-header h2 { margin: 0; }
  .music-panel h3, .stay-panel h3, .card-panel h3, .queue-panel h3 { margin: 20px 0 10px; color: #bae6fd; font-size: 15px; }
  .stay-chart-wrap { max-height: 420px; overflow: auto; }
  .stay-bar-row { display: grid; grid-template-columns: minmax(112px, 160px) minmax(180px, 1fr) auto; gap: 12px; align-items: center; }
  .stay-bar-track { height: 18px; overflow: hidden; border-radius: 999px; background: rgba(15, 23, 42, .88); box-shadow: inset 0 0 0 1px rgba(148, 163, 184, .22); }
  .stay-bar-fill { width: 0%; min-width: 0; transition: width .24s ease; background: linear-gradient(90deg, #22d3ee, #a3e635); box-shadow: 0 0 18px rgba(34, 211, 238, .38); }
  .stay-calendar-grid { display: grid; grid-template-columns: repeat(7, minmax(112px, 1fr)); }
  .stay-calendar-day { min-height: 112px; }
  .inline-form { display: grid; grid-template-columns: 1fr auto; gap: 10px; }
  .inline-form input { min-width: 0; padding: 14px 16px; border: 1px solid rgba(148,163,184,.35); border-radius: 8px; color: #f8fafc; background: #0f141a; }
  .inline-form button, .wide-button, .track-button { border: 1px solid rgba(255,255,255,.18); color: #f8fafc; background: rgba(20,184,166,.86); cursor: pointer; }
  .inline-form button, .wide-button { display: inline-flex; align-items: center; justify-content: center; padding: 12px 20px; border-radius: 8px; text-decoration: none; }
  .spotify-connect-row { display: flex; align-items: center; flex-wrap: wrap; gap: 10px; margin: 0 0 14px; }
  .spotify-connect-state { color: #d1fae5; font-size: 13px; }
  .music-section-title { margin: 22px 0 10px; color: #bae6fd; font-size: 15px; font-weight: 700; }
  .list-panel { display: grid; gap: 8px; }
  .track-row { display: grid; grid-template-columns: 52px 1fr auto auto; align-items: center; gap: 12px; padding: 10px; border-radius: 8px; background: rgba(255,255,255,.04); }
  .track-row:hover { background: rgba(255,255,255,.07); }
  .track-row img { width: 44px; height: 44px; border-radius: 4px; object-fit: cover; background: #0f141a; }
  .track-row div { min-width: 0; }
  .track-row strong, .track-row span { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .track-row strong.is-added { color: #1ed760; }
  .track-row span, .muted { color: #94a3b8; font-size: 13px; }
  .track-kind { display: inline-block; width: 11px; height: 11px; margin-right: 4px; border: 1px solid currentColor; border-radius: 2px; vertical-align: -1px; }
  .track-menu { color: #cbd5e1; font-weight: 700; letter-spacing: 3px; }
  .track-icon-button { display: grid; place-items: center; width: 28px; height: 28px; padding: 0; border: 0; border-radius: 999px; color: #cbd5e1; background: transparent; font-size: 23px; line-height: 1; }
  .track-icon-button:hover { color: #f8fafc; background: rgba(255,255,255,.08); }
  .track-icon-button.is-added { color: #111827; background: #1ed760; font-size: 16px; }
  .result-box { min-height: 120px; margin-top: 14px; padding: 14px; overflow: auto; border-radius: 8px; color: #d1fae5; background: #0f141a; white-space: pre-wrap; }
  .photo-gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(132px, 1fr)); gap: 12px; }
  .photo-gallery figure { overflow: hidden; border: 1px solid rgba(148,163,184,.3); border-radius: 8px; background: rgba(15,23,42,.55); }
  .photo-gallery img { width: 100%; aspect-ratio: 1; object-fit: cover; background: rgba(15,23,42,.9); }
  .photo-gallery figcaption { padding: 8px; color: #94a3b8; font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .photo-modal-box { position: relative; }
  .photo-modal-close { position: absolute; top: 8px; right: 8px; }
  .card-modal-box { position: relative; }
  .card-modal-close { position: absolute; top: 8px; right: 8px; }
  .portal-user-menu { z-index: 60; width: 13rem; margin-top: 8px; }
  @media (max-width: 720px) { .portal-topbar { flex-direction: column; } .music-panel, .stay-panel, .card-panel, .queue-panel { width: calc(100vw - 24px); padding: 22px; } .inline-form, .track-row, .stay-bar-row { grid-template-columns: 1fr; } .track-row img { display: none; } .portal-status { text-align: left; } .stay-calendar-scroll { overflow-x: auto; } .stay-calendar-grid { min-width: 784px; } }
</style>

<div class="portal-shell">
  <canvas id="canvas-3d" aria-label="研究室 3D 空間"></canvas>

  <header class="portal-topbar">
    <div>
      <p class="portal-kicker">Room Portal</p>
      <h1>研究室 3D ポータル</h1>
    </div>
    <div class="topbar-actions flex items-center gap-3">
      <div class="portal-status" id="room-status"><%= notice.presence || alert.presence || current_user&.name || "API 準備中" %></div>
      <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-sm btn-outline" %>
    </div>
  </header>

  <nav class="portal-sidebar" aria-label="機能メニュー">
    <button class="portal-action btn btn-outline justify-start" type="button" data-open-music>
      <span>Music</span>
      楽曲検索・登録
    </button>
    <button class="portal-action btn btn-outline justify-start" type="button" data-open-card>
      <span>Card</span>
      カード登録
    </button>
    <button class="portal-action btn btn-outline justify-start" type="button" data-open-photo>
      <span>Photo</span>
      写真を追加
    </button>
    <button class="portal-action" type="button" data-open-stay>
      <span>Stay</span>
      滞在ログ
    </button>
    <button class="portal-action btn btn-outline justify-start" type="button" data-open-queue>
      <span>Queue</span>
      選曲実行
    </button>
  </nav>

  <section class="music-panel" id="music-panel" aria-label="楽曲検索・登録">
    <form method="dialog">
      <button class="modal-close" type="button" data-close-music aria-label="閉じる">x</button>
    </form>
    <div class="music-panel-header">
      <h2 class="portal-panel-title">楽曲検索・登録</h2>
    </div>
    <div class="spotify-connect-row">
      <%= link_to "Spotifyを連携", spotify_authorize_path, class: "wide-button" %>
      <% if @spotify_connected %>
        <span class="spotify-connect-state">連携済み: ryouアカウントのSpotify Player APIを使えます。</span>
      <% else %>
        <span class="muted">Alexa再生にはSpotify連携が必要です。</span>
      <% end %>
    </div>
    <% unless @spotify_env_ready %>
      <p class="muted">Spotify 検索を使うには .env に SPOTIFY_CLIENT_ID と SPOTIFY_CLIENT_SECRET を設定して、Rails を再起動してください。</p>
    <% end %>
    <% unless @spotify_player_ready %>
      <p class="muted">Alexaへ再生するには「Spotifyを連携」からryouアカウントで認可してください。</p>
    <% end %>

    <div class="inline-form" style="margin-bottom: 14px;">
      <select id="spotify-device-select" class="input input-bordered" aria-label="再生先">
        <option value="">再生先を読み込み中...</option>
      </select>
      <button id="spotify-device-refresh-button" type="button">再生先更新</button>
    </div>

    <div class="inline-form">
      <input id="music-search-input" type="search" placeholder="曲名またはアーティスト名" autocomplete="off">
      <button id="music-search-button" type="button">検索</button>
    </div>

    <section>
      <h3 class="music-section-title">検索結果</h3>
      <div class="list-panel" id="music-search-results">
        <p class="muted">Spotify から曲を検索できます。</p>
      </div>
    </section>

    <section>
      <h3 class="music-section-title">お気に入り</h3>
      <div class="list-panel" id="favorite-tracks">
        <% if @favorite_tracks.any? %>
          <% @favorite_tracks.each do |track| %>
            <article class="track-row" data-favorite-track-id="<%= track.spotify_track_id %>">
              <% if track.image_url.present? %>
                <img src="<%= track.image_url %>" alt="">
              <% else %>
                <img alt="">
              <% end %>
              <div>
                <strong class="is-added"><%= track.track_name %></strong>
                <span><span class="track-kind"></span>楽曲・<%= track.artist_name %></span>
              </div>
              <%= tag.button "▶", class: "track-button", type: "button", data: { spotify_track_id: track.spotify_track_id }, aria: { label: "再生" } %>
              <button class="track-button is-added" type="button" data-remove-track="<%= track.id %>" data-remove-spotify-track-id="<%= track.spotify_track_id %>" aria-label="お気に入りから削除">✓</button>
            </article>
          <% end %>
        <% else %>
          <p class="muted">登録済みの曲はありません。</p>
        <% end %>
      </div>
    </section>
  </section>

  <dialog id="card-panel" class="modal" aria-label="IDm再設定">
    <div class="modal-box card-modal-box bg-base-100 text-base-content">
      <form method="dialog">
        <button class="card-modal-close btn btn-sm btn-circle btn-ghost" type="submit" data-close-card aria-label="閉じる">x</button>
      </form>
      <h2 class="portal-panel-title mb-5">IDmの再設定</h2>
      <div class="form-control w-full">
        <label class="label" for="card-idm-input">
          <span class="label-text">ICカードのIDm</span>
        </label>
        <div class="join w-full">
          <input id="card-idm-input" class="input input-bordered join-item w-full" type="text" placeholder="0123456789ABCDEF" autocomplete="off">
          <button id="card-register-button" class="btn btn-primary join-item" type="button">登録</button>
        </div>
      </div>
      <p class="muted mt-4">ICカードのIDmをログイン中のユーザーに登録します。</p>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button type="submit">閉じる</button>
    </form>
  </dialog>

  <section class="stay-panel" id="stay-panel" aria-label="入退室ダッシュボード">
    <div class="stay-panel-header">
      <h2>研究室滞在時間ダッシュボード</h2>
      <button class="btn btn-sm btn-outline" type="button" data-close-stay>閉じる</button>
    </div>

    <div class="grid gap-3 md:grid-cols-3">
      <div class="rounded-lg border border-white/40 bg-base-100/85 p-4 shadow">
        <div class="text-sm text-base-content/70">今日の滞在時間</div>
        <div class="mt-2 text-2xl font-bold"><%= format_stay_duration(@my_access_summary[:today_seconds]) %></div>
      </div>
      <div class="rounded-lg border border-white/40 bg-base-100/85 p-4 shadow">
        <div class="text-sm text-base-content/70">今週の合計</div>
        <div class="mt-2 text-2xl font-bold"><%= format_stay_duration(@my_access_summary[:week_seconds]) %></div>
      </div>
      <div class="rounded-lg border border-white/40 bg-base-100/85 p-4 shadow">
        <div class="text-sm text-base-content/70">今月の合計</div>
        <div class="mt-2 text-2xl font-bold"><%= format_stay_duration(@my_access_summary[:month_seconds]) %></div>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
      <h3 class="m-0">表示切り替え</h3>
      <div class="join">
        <button class="btn btn-sm btn-primary join-item" type="button" data-stay-view="chart">グラフ</button>
        <button class="btn btn-sm join-item" type="button" data-stay-view="calendar">カレンダー</button>
      </div>
    </div>

    <section data-stay-section="chart">
      <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
        <h3>メンバー比較</h3>
        <div class="join">
          <button class="btn btn-sm join-item" type="button" data-stay-sort="today">今日</button>
          <button class="btn btn-sm btn-primary join-item" type="button" data-stay-sort="week">今週</button>
          <button class="btn btn-sm join-item" type="button" data-stay-sort="month">今月</button>
          <button class="btn btn-sm join-item" type="button" data-stay-sort="in_room">入室中</button>
        </div>
      </div>
      <div class="stay-chart-wrap grid gap-2 rounded-lg border border-white/30 bg-base-100/90 p-4" data-stay-chart>
        <% @room_access_rows.each do |row| %>
          <div
            class="rounded-lg border border-base-300 bg-base-200/70 p-3"
            data-stay-row
            data-in-room="<%= row[:in_room] ? 'true' : 'false' %>"
            data-today-seconds="<%= row[:today_seconds] %>"
            data-week-seconds="<%= row[:week_seconds] %>"
            data-month-seconds="<%= row[:month_seconds] %>"
            data-current-seconds="<%= row[:current_duration_seconds] %>"
            data-today-label="<%= format_stay_duration(row[:today_seconds]) %>"
            data-week-label="<%= format_stay_duration(row[:week_seconds]) %>"
            data-month-label="<%= format_stay_duration(row[:month_seconds]) %>"
            data-current-label="<%= format_stay_duration(row[:current_duration_seconds]) %>"
            data-current-since="<%= row[:current_since] ? row[:current_since].strftime('%m/%d %H:%M') : '-' %>"
            data-user-name="<%= row[:user].name %>"
          >
            <div class="stay-bar-row">
              <div class="min-w-0">
                <div class="truncate font-semibold"><%= row[:user].name %></div>
                <div class="text-xs text-base-content/70" data-stay-subtitle>
                  今週 <%= format_stay_duration(row[:week_seconds]) %>
                </div>
              </div>
              <div class="stay-bar-track">
                <div class="stay-bar-fill h-full rounded-full" data-stay-bar></div>
              </div>
              <div class="flex min-w-28 items-center justify-end gap-2">
                <span class="badge badge-info badge-sm font-semibold text-info-content" data-stay-value><%= format_stay_duration(row[:week_seconds]) %></span>
                <% if row[:in_room] %>
                  <span class="badge badge-success badge-sm">入室中</span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <section class="mt-6 hidden" data-stay-section="calendar">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
        <h3 class="m-0">自分の滞在カレンダー</h3>
        <div class="join">
          <button class="btn btn-sm join-item" type="button" data-calendar-prev>前月</button>
          <span class="btn btn-sm join-item pointer-events-none" data-calendar-label><%= @calendar_initial_month.year %>年<%= @calendar_initial_month.month %>月</span>
          <button class="btn btn-sm join-item" type="button" data-calendar-next>次月</button>
        </div>
      </div>

      <div class="stay-calendar-scroll rounded-lg border border-base-300 bg-base-100/90">
        <div class="stay-calendar-grid border-b border-base-300 bg-base-200/80 text-center text-sm font-semibold text-base-content/70">
          <% %w[日 月 火 水 木 金 土].each do |day_name| %>
            <div class="border-r border-base-300 p-2 last:border-r-0"><%= day_name %></div>
          <% end %>
        </div>
        <div
          class="stay-calendar-grid"
          data-calendar-grid
          data-initial-year="<%= @calendar_initial_month.year %>"
          data-initial-month="<%= @calendar_initial_month.month %>"
        ></div>
      </div>
      <script type="application/json" id="calendar-events-json"><%= raw json_escape(@calendar_events.to_json) %></script>
    </section>
  </section>

  <section class="queue-panel" id="queue-panel" aria-label="選曲実行">
    <div class="queue-panel-header">
      <h2>選曲実行</h2>
      <button class="btn btn-sm btn-outline" type="button" data-close-queue>閉じる</button>
    </div>
    <button id="queue-play-button" type="button" class="wide-button">ルーレットで曲を選ぶ</button>
    <pre id="queue-result" class="result-box"></pre>
  </section>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
<script src="/3d_room.js"></script>
<script>
  const apiBase = "/api/v1";
  const musicPanel = document.getElementById("music-panel");
  const cardPanel = document.getElementById("card-panel");
  const stayPanel = document.getElementById("stay-panel");
  const queuePanel = document.getElementById("queue-panel");
  const photoModal = document.getElementById("photo-modal");
  const photoInput = document.getElementById("photo-input");
  const photoGallery = document.getElementById("photo-gallery");
  const photoListSection = document.getElementById("photo-list-section");
  const photoListToggle = document.getElementById("photo-list-toggle");
  const photoMessage = document.getElementById("photo-message");
  const photoCount = document.getElementById("photo-count");
  const previewPlayer = document.getElementById("spotify-preview-player");
  const musicSearchInput = document.getElementById("music-search-input");
  const spotifyDeviceSelect = document.getElementById("spotify-device-select");
  const spotifyDeviceRefreshButton = document.getElementById("spotify-device-refresh-button");
  const stayRows = Array.from(document.querySelectorAll("[data-stay-row]"));
  const staySortButtons = Array.from(document.querySelectorAll("[data-stay-sort]"));
  const stayViewButtons = Array.from(document.querySelectorAll("[data-stay-view]"));
  const staySections = Array.from(document.querySelectorAll("[data-stay-section]"));
  const calendarGrid = document.querySelector("[data-calendar-grid]");
  const calendarLabel = document.querySelector("[data-calendar-label]");
  const calendarPrev = document.querySelector("[data-calendar-prev]");
  const calendarNext = document.querySelector("[data-calendar-next]");
  const calendarEvents = JSON.parse(document.getElementById("calendar-events-json")?.textContent || "[]");
  const calendarEventsByDate = calendarEvents.reduce((result, event) => {
    result[event.date] ||= [];
    result[event.date].push(event);
    return result;
  }, {});
  let activeCalendarMonth = new Date(
    Number(calendarGrid?.dataset.initialYear || new Date().getFullYear()),
    Number(calendarGrid?.dataset.initialMonth || new Date().getMonth() + 1) - 1,
    1
  );
  const favoriteTrackIds = new Set(
    Array.from(document.querySelectorAll("[data-favorite-track-id]")).map((element) => element.dataset.favoriteTrackId)
  );
  let playingSpotifyTrackId = null;
  let activePlaybackButton = null;
  let spotifyPlaybackRequestInFlight = false;

  document.querySelector("[data-open-music]").addEventListener("click", () => {
    closeCardModal();
    stayPanel.classList.remove("is-open");
    queuePanel.classList.remove("is-open");
    closePhotoModal();
    musicPanel.classList.add("is-open");
    loadSpotifyDevices();
    musicSearchInput.focus();
  });
  document.querySelector("[data-close-music]").addEventListener("click", () => {
    musicPanel.classList.remove("is-open");
    setStatus("<%= j current_user.name %>");
  });
  document.querySelectorAll("[data-open-card]").forEach((button) => {
    button.addEventListener("click", openCardModal);
  });
  document.querySelector("[data-close-card]").addEventListener("click", () => {
    closeCardModal();
    setStatus("<%= j current_user.name %>");
  });
  document.querySelector("[data-open-stay]").addEventListener("click", () => {
    musicPanel.classList.remove("is-open");
    closeCardModal();
    queuePanel.classList.remove("is-open");
    closePhotoModal();
    stayPanel.classList.add("is-open");
  });
  document.querySelector("[data-close-stay]").addEventListener("click", () => {
    stayPanel.classList.remove("is-open");
    setStatus("<%= j current_user.name %>");
  });
  document.querySelector("[data-open-queue]").addEventListener("click", () => {
    musicPanel.classList.remove("is-open");
    closeCardModal();
    stayPanel.classList.remove("is-open");
    closePhotoModal();
    queuePanel.classList.add("is-open");
  });
  document.querySelector("[data-close-queue]").addEventListener("click", () => {
    queuePanel.classList.remove("is-open");
    setStatus("<%= j current_user.name %>");
  });
  document.querySelector("[data-open-photo]")?.addEventListener("click", () => {
    musicPanel.classList.remove("is-open");
    closeCardModal();
    stayPanel.classList.remove("is-open");
    queuePanel.classList.remove("is-open");
    renderPhotoGallery();
    if (photoModal?.showModal) photoModal.showModal();
  });
  document.getElementById("photo-upload-button")?.addEventListener("click", uploadPhotos);
  photoListToggle?.addEventListener("click", () => {
    photoListSection?.classList.toggle("hidden");
    renderPhotoGallery();
  });
  staySortButtons.forEach((button) => {
    button.addEventListener("click", () => sortStayRows(button.dataset.staySort));
  });
  stayViewButtons.forEach((button) => {
    button.addEventListener("click", () => switchStayView(button.dataset.stayView));
  });
  calendarPrev?.addEventListener("click", () => {
    activeCalendarMonth = new Date(activeCalendarMonth.getFullYear(), activeCalendarMonth.getMonth() - 1, 1);
    renderCalendarMonth();
  });
  calendarNext?.addEventListener("click", () => {
    activeCalendarMonth = new Date(activeCalendarMonth.getFullYear(), activeCalendarMonth.getMonth() + 1, 1);
    renderCalendarMonth();
  });
  sortStayRows("week");
  switchStayView("chart");
  renderCalendarMonth();
  spotifyDeviceRefreshButton.addEventListener("click", loadSpotifyDevices);
  loadSpotifyDevices();
  document.getElementById("music-search-button").addEventListener("click", searchTracks);
  document.getElementById("music-search-input").addEventListener("keydown", (event) => {
    if (event.key === "Enter") searchTracks();
  });
  bindFavoriteRemoveButtons();
  bindPreviewButtons();

  async function loadSpotifyDevices() {
    spotifyDeviceSelect.innerHTML = `<option value="">再生先を取得中...</option>`;
    const response = await fetch(`${apiBase}/spotify/devices`);
    const data = await response.json().catch(() => ({}));

    if (data.status !== "success") {
      spotifyDeviceSelect.innerHTML = `<option value="">再生先を取得できません</option>`;
      setStatus(data.message || "Spotify再生先を取得できません");
      return;
    }

    const devices = data.devices || [];
    spotifyDeviceSelect.innerHTML = devices.map((device) => `
      <option value="${escapeHtml(device.id)}" ${device.is_active ? "selected" : ""}>
        ${escapeHtml(device.name)} / ${escapeHtml(device.type)}
      </option>
    `).join("") || `<option value="">Spotify Connect端末がありません</option>`;
  }

  document.getElementById("card-register-button").addEventListener("click", async () => {
    const idm = document.getElementById("card-idm-input").value.trim();
    if (!idm) return setStatus("IDm を入力してください");

    const response = await fetch(`${apiBase}/cards`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ idm }),
    });
    const data = await response.json();
    setStatus(data.status === "success" ? "カードを登録しました" : data.message);
  });

  document.getElementById("queue-play-button").addEventListener("click", async () => {
    const response = await fetch(`${apiBase}/alexa/play_queue`, { method: "POST" });
    const data = await response.json();
    document.getElementById("queue-result").textContent = JSON.stringify(data, null, 2);
  });

  async function searchTracks() {
    const query = document.getElementById("music-search-input").value.trim();
    if (!query) return setStatus("検索語を入力してください");

    setStatus("検索中");
    const response = await fetch(`${apiBase}/spotify/search?q=${encodeURIComponent(query)}`);
    const data = await response.json();
    const container = document.getElementById("music-search-results");

    if (data.status !== "success") {
      container.innerHTML = `<p class="muted">${escapeHtml(data.message || "検索に失敗しました")}</p>`;
      setStatus("検索に失敗しました");
      return;
    }

    container.innerHTML = data.results.map((track) => `
      <article class="track-row">
        ${track.image_url ? `<img src="${escapeHtml(track.image_url)}" alt="">` : "<img alt=\"\">"}
        <div>
          <strong class="${favoriteTrackIds.has(track.spotify_track_id) ? "is-added" : ""}">${escapeHtml(track.track_name)}</strong>
          <span><span class="track-kind"></span>楽曲・${escapeHtml(track.artist_name || "")}</span>
        </div>
        ${previewButtonHtml(track)}
        ${favoriteTrackIds.has(track.spotify_track_id)
          ? `<button class="track-button is-added" type="button" disabled aria-label="登録済み">✓</button>`
          : `<button class="track-button" type="button" data-track="${encodeURIComponent(JSON.stringify(track))}" aria-label="お気に入りに追加">＋</button>`}
      </article>
    `).join("") || `<p class="muted">該当する曲がありません。</p>`;

    bindPreviewButtons(container);
    container.querySelectorAll("[data-track]").forEach((button) => {
      button.addEventListener("click", () => addTrack(JSON.parse(decodeURIComponent(button.dataset.track))));
    });
    setStatus("検索完了");
  }

  async function addTrack(track) {
    const response = await fetch(`${apiBase}/spotify/tracks`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ track }),
    });
    const data = await response.json();
    setStatus(data.status === "success" ? "お気に入りに追加しました" : data.message);
    if (data.status === "success") favoriteTrackIds.add(track.spotify_track_id);
    refreshSearchResultButtons();
    loadFavoriteTracks();
  }

  async function loadFavoriteTracks() {
    const response = await fetch(`${apiBase}/spotify/tracks`);
    const data = await response.json();
    const container = document.getElementById("favorite-tracks");

    if (data.status !== "success") {
      container.innerHTML = `<p class="muted">${escapeHtml(data.message || "お気に入りを取得できませんでした")}</p>`;
      return;
    }

    container.innerHTML = data.tracks.map((track) => `
      <article class="track-row" data-favorite-track-id="${track.spotify_track_id}">
        ${track.image_url ? `<img src="${escapeHtml(track.image_url)}" alt="">` : "<img alt=\"\">"}
        <div>
          <strong class="is-added">${escapeHtml(track.track_name)}</strong>
          <span><span class="track-kind"></span>楽曲・${escapeHtml(track.artist_name)}</span>
        </div>
        ${previewButtonHtml(track)}
        <button class="track-button is-added" type="button" data-remove-track="${track.id}" data-remove-spotify-track-id="${track.spotify_track_id}" aria-label="お気に入りから削除">✓</button>
      </article>
    `).join("") || `<p class="muted">登録済みの曲はありません。</p>`;

    bindPreviewButtons(container);
    bindFavoriteRemoveButtons(container);
  }

  function bindFavoriteRemoveButtons(scope = document) {
    scope.querySelectorAll("[data-remove-track]").forEach((button) => {
      button.addEventListener("click", async () => {
        await fetch(`${apiBase}/spotify/tracks/${button.dataset.removeTrack}`, { method: "DELETE" });
        if (button.dataset.removeSpotifyTrackId) favoriteTrackIds.delete(button.dataset.removeSpotifyTrackId);
        setStatus("お気に入りから削除しました");
        loadFavoriteTracks();
      });
    });
  }

  function previewButtonHtml(track) {
    return `<button class="track-button" type="button" data-spotify-track-id="${escapeHtml(track.spotify_track_id)}" aria-label="再生">▶</button>`;
  }

  function bindPreviewButtons(scope = document) {
    scope.querySelectorAll("[data-spotify-track-id]").forEach((button) => {
      if (button.dataset.playbackBound === "true") return;
      button.dataset.playbackBound = "true";
      button.addEventListener("click", () => toggleSpotifyPlayback(button));
    });
  }

  async function toggleSpotifyPlayback(button) {
    if (spotifyPlaybackRequestInFlight) return;

    const spotifyTrackId = button.dataset.spotifyTrackId;
    if (!spotifyTrackId) return;
    const deviceId = spotifyDeviceSelect.value;
    if (!deviceId) {
      setStatus("再生先を選択してください");
      return;
    }

    spotifyPlaybackRequestInFlight = true;
    button.disabled = true;

    if (playingSpotifyTrackId === spotifyTrackId) {
      setStatus("停止中");
      try {
        const response = await fetch(`${apiBase}/spotify/pause`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ device_id: deviceId }),
        });
        const data = await response.json().catch(() => ({}));

        if (response.ok || data.status === "success") {
          resetPlaybackButtons();
          setStatus("再生を停止しました");
        } else {
          setStatus(data.message || "停止に失敗しました");
        }
      } catch {
        resetPlaybackButtons();
        setStatus("再生状態をリセットしました");
      } finally {
        button.disabled = false;
        spotifyPlaybackRequestInFlight = false;
      }
      return;
    }

    setStatus("再生中");
    try {
      const response = await fetch(`${apiBase}/spotify/play`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ spotify_track_id: spotifyTrackId, device_id: deviceId }),
      });
      const data = await response.json().catch(() => ({}));

      if (data.status === "success") {
        resetPlaybackButtons();
        playingSpotifyTrackId = spotifyTrackId;
        activePlaybackButton = button;
        button.textContent = "■";
        button.setAttribute("aria-label", "停止");
        setStatus("再生中");
      } else if (data.code === "SPOTIFY_PLAYER_TOKEN_REQUIRED") {
        resetPlaybackButtons();
        setStatus("SPOTIFY_REFRESH_TOKEN が必要です");
      } else {
        resetPlaybackButtons();
        setStatus(data.message || "再生に失敗しました");
      }
    } catch {
      resetPlaybackButtons();
      setStatus("再生に失敗しました");
    } finally {
      button.disabled = false;
      spotifyPlaybackRequestInFlight = false;
    }
  }

  function resetPlaybackButtons() {
    document.querySelectorAll("[data-spotify-track-id]").forEach((button) => {
      button.textContent = "▶";
      button.setAttribute("aria-label", "再生");
      button.disabled = false;
    });
    playingSpotifyTrackId = null;
    activePlaybackButton = null;
  }

  function refreshSearchResultButtons() {
    document.querySelectorAll("[data-track]").forEach((button) => {
      const track = JSON.parse(decodeURIComponent(button.dataset.track));
      if (!favoriteTrackIds.has(track.spotify_track_id)) return;

      const row = button.closest(".track-row");
      row.querySelector("strong").classList.add("is-added");
      button.outerHTML = `<button class="track-button is-added" type="button" disabled aria-label="登録済み">✓</button>`;
    });
  }

  async function loadAccessLogs() {
    const response = await fetch(`${apiBase}/access_logs`);
    const data = await response.json();
    const container = document.getElementById("access-log-list");
    container.innerHTML = data.logs.map((log) => `
      <article class="track-row">
        <div>
          <strong>${log.action_type === "in" ? "入室" : "退室"}</strong>
          <span>${new Date(log.timestamp).toLocaleString()}</span>
        </div>
      </article>
    `).join("") || `<p class="muted">滞在ログはまだありません。</p>`;
  }

  function setStatus(message) {
    document.getElementById("room-status").textContent = message;
  }

  function closePhotoModal() {
    if (photoModal?.open) photoModal.close();
  }

  function openCardModal() {
    musicPanel.classList.remove("is-open");
    stayPanel.classList.remove("is-open");
    queuePanel.classList.remove("is-open");
    closePhotoModal();
    closeUserMenu();
    if (cardPanel.showModal) {
      if (!cardPanel.open) cardPanel.showModal();
    } else {
      cardPanel.classList.add("is-open");
    }
    document.getElementById("card-idm-input").focus();
  }

  function closeCardModal() {
    if (cardPanel.close && cardPanel.open) {
      cardPanel.close();
    } else {
      cardPanel.classList.remove("is-open");
    }
  }

  function closeUserMenu() {
    document.querySelectorAll(".portal-topbar details.dropdown").forEach((dropdown) => {
      dropdown.removeAttribute("open");
    });
  }

  async function uploadPhotos() {
    const files = Array.from(photoInput.files || []);
    if (files.length === 0) {
      photoMessage.textContent = "写真を選択してください。";
      return;
    }

    const imageFiles = files.filter((file) => file.type.startsWith("image/"));
    if (imageFiles.length !== files.length) {
      photoMessage.textContent = "画像ファイル以外はアップロードできません。";
    }
    if (imageFiles.length === 0) return;

    const oversizedFiles = imageFiles.filter((file) => file.size > 5 * 1024 * 1024);
    if (oversizedFiles.length > 0) {
      photoMessage.textContent = "5MBを超える写真はアップロードできません。";
      return;
    }

    try {
      const newPhotos = await Promise.all(imageFiles.map((file) => readPhotoFile(file)));
      const responses = await Promise.all(newPhotos.map((photo) => fetch(`${apiBase}/photos`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ photo }),
      })));

      const failed = responses.find((response) => !response.ok);
      if (failed) {
        const data = await failed.json();
        photoMessage.textContent = data.message || "写真のアップロードに失敗しました。";
        return;
      }

      photoInput.value = "";
      photoListSection.classList.remove("hidden");
      photoMessage.textContent = `${newPhotos.length}枚の写真をアップロードしました。`;
      setStatus("写真をアップロードしました");
      renderPhotoGallery();
    } catch {
      photoMessage.textContent = "写真のアップロードに失敗しました。";
    }
  }

  function readPhotoFile(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve({
        filename: file.name,
        content_type: file.type,
        byte_size: file.size,
        image_data: reader.result,
      });
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  async function renderPhotoGallery() {
    if (!photoMessage || !photoGallery) return;

    photoMessage.textContent = "写真を読み込み中です。";
    const response = await fetch(`${apiBase}/photos`);
    const data = await response.json();

    if (data.status !== "success") {
      photoMessage.textContent = data.message || "写真を取得できませんでした。";
      return;
    }

    const photos = data.photos || [];
    if (photoCount) photoCount.textContent = `${data.count || photos.length}枚`;
    photoGallery.innerHTML = photos.map((photo) => `
      <figure>
        <img src="${escapeHtml(photo.image_data)}" alt="${escapeHtml(photo.filename)}">
        <figcaption title="${escapeHtml(photo.filename)}">${escapeHtml(photo.filename)}</figcaption>
      </figure>
    `).join("") || `<p class="muted">アップロードした写真はまだありません。</p>`;
    photoMessage.textContent = "画像ファイルのみアップロードできます。";
  }

  function switchStayView(view) {
    stayViewButtons.forEach((button) => {
      const isActive = button.dataset.stayView === view;
      button.classList.toggle("btn-primary", isActive);
      button.classList.toggle("btn-ghost", !isActive);
    });

    staySections.forEach((section) => {
      section.classList.toggle("hidden", section.dataset.staySection !== view);
    });
  }

  function renderCalendarMonth() {
    if (!calendarGrid) return;

    const year = activeCalendarMonth.getFullYear();
    const month = activeCalendarMonth.getMonth();
    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const startDay = new Date(firstDay);
    startDay.setDate(firstDay.getDate() - firstDay.getDay());
    const endDay = new Date(lastDay);
    endDay.setDate(lastDay.getDate() + (6 - lastDay.getDay()));

    if (calendarLabel) calendarLabel.textContent = `${year}年${month + 1}月`;

    const todayKey = dateKey(new Date());
    const cells = [];
    for (let day = new Date(startDay); day <= endDay; day.setDate(day.getDate() + 1)) {
      const key = dateKey(day);
      const events = calendarEventsByDate[key] || [];
      const inMonth = day.getMonth() === month;
      const dayClass = inMonth ? "bg-base-100" : "bg-base-200/50 text-base-content/40";
      const dateLabelClass = key === todayKey ? "badge badge-primary badge-sm" : "text-sm font-semibold";
      const eventCount = events.length > 0 ? `<span class="badge badge-outline badge-xs">${events.length}件</span>` : "";
      const eventHtml = events.map((event) => `
        <div class="rounded-md bg-info px-2 py-1 text-xs font-semibold text-white">
          <div class="truncate">${formatCalendarTime(event.started_at)} - ${event.open ? "滞在中" : formatCalendarTime(event.ended_at)}</div>
          <div class="text-white/80">${formatDuration(event.duration_seconds)}</div>
        </div>
      `).join("");

      cells.push(`
        <div class="stay-calendar-day border-b border-r border-base-300 p-2 ${dayClass}">
          <div class="mb-2 flex items-center justify-between gap-2">
            <span class="${dateLabelClass}">${day.getDate()}</span>
            ${eventCount}
          </div>
          <div class="grid gap-1">${eventHtml}</div>
        </div>
      `);
    }

    calendarGrid.innerHTML = cells.join("");
  }

  function dateKey(date) {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");
    return `${year}-${month}-${day}`;
  }

  function formatCalendarTime(value) {
    const date = new Date(value);
    return `${String(date.getHours()).padStart(2, "0")}:${String(date.getMinutes()).padStart(2, "0")}`;
  }

  function formatDuration(seconds) {
    const totalMinutes = Math.max(Math.floor(Number(seconds || 0) / 60), 0);
    const hours = Math.floor(totalMinutes / 60);
    const minutes = totalMinutes % 60;
    if (hours === 0) return `${minutes}分`;

    return `${hours}時間${String(minutes).padStart(2, "0")}分`;
  }

  function sortStayRows(mode) {
    const chart = document.querySelector("[data-stay-chart]");
    if (!chart) return;

    staySortButtons.forEach((button) => {
      const isActive = button.dataset.staySort === mode;
      button.classList.toggle("btn-primary", isActive);
      button.classList.toggle("btn-ghost", !isActive);
    });

    const secondsKey = mode === "in_room" ? "currentSeconds" : `${mode}Seconds`;
    const sortedRows = [...stayRows].sort((a, b) => {
      if (mode === "in_room") {
        const roomCompare = Number(b.dataset.inRoom === "true") - Number(a.dataset.inRoom === "true");
        if (roomCompare !== 0) return roomCompare;
        return Number(b.dataset.currentSeconds) - Number(a.dataset.currentSeconds) || a.dataset.userName.localeCompare(b.dataset.userName, "ja");
      }

      return Number(b.dataset[secondsKey]) - Number(a.dataset[secondsKey]) || a.dataset.userName.localeCompare(b.dataset.userName, "ja");
    });
    const visibleRows = sortedRows.filter((row) => mode !== "in_room" || row.dataset.inRoom === "true");
    const maxSeconds = Math.max(...visibleRows.map((row) => Number(row.dataset[secondsKey])), 0);

    sortedRows.forEach((row) => {
      row.hidden = mode === "in_room" && row.dataset.inRoom !== "true";
      const seconds = Number(row.dataset[secondsKey]);
      const bar = row.querySelector("[data-stay-bar]");
      const value = row.querySelector("[data-stay-value]");
      const subtitle = row.querySelector("[data-stay-subtitle]");
      const width = maxSeconds > 0 ? Math.max((seconds / maxSeconds) * 100, seconds > 0 ? 4 : 0) : 0;

      if (bar) bar.style.width = `${width}%`;
      if (value) value.textContent = row.dataset[`${mode === "in_room" ? "current" : mode}Label`];
      if (subtitle) subtitle.textContent = staySubtitle(row, mode);
      chart.appendChild(row);
    });
  }

  function staySubtitle(row, mode) {
    if (mode === "today") return `今日 ${row.dataset.todayLabel}`;
    if (mode === "month") return `今月 ${row.dataset.monthLabel}`;
    if (mode === "in_room") return `入室開始 ${row.dataset.currentSince}`;
    return `今週 ${row.dataset.weekLabel}`;
  }

  function escapeHtml(value) {
    const div = document.createElement("div");
    div.textContent = value || "";
    return div.innerHTML;
  }

  setStatus("API 接続待機中");
</script>

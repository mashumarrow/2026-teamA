<style>
  .portal-shell { position: relative; min-height: 100vh; overflow: hidden; background: #101418; color: #f8fafc; }
  #canvas-3d { position: fixed; inset: 0; z-index: 0; width: 100vw; height: 100vh; }
  .portal-topbar, .portal-sidebar, .music-panel { position: fixed; z-index: 20; }
  .portal-topbar { top: 18px; left: 22px; right: 22px; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; pointer-events: none; }
  .portal-topbar .topbar-actions { pointer-events: auto; }
  .portal-kicker { margin: 0; color: #7dd3fc; font-size: 12px; font-weight: 700; text-transform: uppercase; }
  .portal-topbar h1 { margin: 2px 0 0; font-size: clamp(22px, 3vw, 38px); letter-spacing: 0; }
  .portal-status { max-width: 320px; padding: 10px 14px; border: 1px solid rgba(255,255,255,.18); border-radius: 8px; background: rgba(16,20,24,.72); color: #d1fae5; font-size: 13px; text-align: right; backdrop-filter: blur(10px); }
  .portal-sidebar { left: 22px; bottom: 22px; display: grid; gap: 10px; width: min(280px, calc(100vw - 44px)); pointer-events: auto; }
  .portal-action { display: grid; gap: 4px; min-height: 62px; padding: 14px 16px; border: 1px solid rgba(255,255,255,.22); border-radius: 8px; color: #f8fafc; background: rgba(15,23,42,.88); text-align: left; cursor: default; box-shadow: 0 12px 34px rgba(0,0,0,.35); }
  .portal-action[data-open-music] { cursor: pointer; }
  .portal-action[data-open-music]:hover { border-color: rgba(147,197,253,.62); background: rgba(15,23,42,.96); }
  .portal-action span { color: #93c5fd; font-size: 12px; font-weight: 700; text-transform: uppercase; }
  .portal-sidebar.is-hidden { display: none; }
  .music-panel { display: none; top: 50%; left: 50%; width: min(960px, calc(100vw - 48px)); max-height: min(620px, calc(100vh - 48px)); overflow: auto; padding: 28px; border: 1px solid rgba(148,163,184,.35); border-radius: 8px; background: rgba(20,26,32,.94); box-shadow: 0 24px 80px rgba(0,0,0,.42); backdrop-filter: blur(12px); transform: translate(-50%, -50%); pointer-events: auto; }
  .music-panel.is-open { display: block; }
  .music-panel h2 { margin: 0 0 16px; font-size: 24px; }
  .music-panel h3 { margin: 20px 0 10px; color: #bae6fd; font-size: 15px; }
  .inline-form { display: grid; grid-template-columns: 1fr auto; gap: 10px; }
  .inline-form input { min-width: 0; padding: 12px 13px; border: 1px solid rgba(148,163,184,.35); border-radius: 8px; color: #f8fafc; background: #0f141a; }
  .inline-form button, .track-row button { padding: 10px 14px; border: 1px solid rgba(255,255,255,.18); border-radius: 8px; color: #f8fafc; background: rgba(20,184,166,.86); cursor: pointer; }
  .list-panel { display: grid; gap: 8px; }
  .track-row { display: grid; grid-template-columns: 52px 1fr auto auto; align-items: center; gap: 12px; padding: 8px 10px; border: 1px solid transparent; border-radius: 8px; background: transparent; }
  .track-row:hover { background: rgba(255,255,255,.05); }
  .track-row img { width: 44px; height: 44px; border-radius: 4px; object-fit: cover; background: #0f141a; }
  .track-row div { min-width: 0; }
  .track-row strong, .track-row span { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .track-row strong.is-added { color: #1ed760; }
  .track-row span, .muted { color: #94a3b8; font-size: 13px; }
  .track-kind { display: inline-block; width: 11px; height: 11px; margin-right: 4px; border: 1px solid currentColor; border-radius: 2px; vertical-align: -1px; }
  .track-menu { color: #cbd5e1; font-weight: 700; letter-spacing: 3px; }
  .track-icon-button { display: grid; place-items: center; width: 28px; height: 28px; padding: 0; border: 0; border-radius: 999px; color: #cbd5e1; background: transparent; font-size: 23px; line-height: 1; }
  .track-icon-button:hover { color: #f8fafc; background: rgba(255,255,255,.08); }
  .track-icon-button.is-added { color: #111827; background: #1ed760; font-size: 16px; }
  @media (max-width: 720px) { .portal-topbar { flex-direction: column; } .music-panel { width: calc(100vw - 24px); padding: 22px; } .inline-form, .track-row { grid-template-columns: 1fr; } .track-row img { display: none; } .portal-status { text-align: left; } }
</style>

<div class="portal-shell">
  <canvas id="canvas-3d" aria-label="研究室 3D 空間"></canvas>

  <header class="portal-topbar">
    <div>
      <p class="portal-kicker">Room Portal</p>
      <h1>研究室 3D ポータル</h1>
    </div>
    <div class="topbar-actions flex items-center gap-3">
      <div class="portal-status" id="room-status"><%= current_user.name %></div>
      <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-sm btn-outline" %>
    </div>
  </header>

  <nav class="portal-sidebar" id="portal-sidebar" aria-label="機能メニュー">
    <button class="portal-action" type="button" data-open-music>
      <span>Music</span>
      楽曲検索・登録
    </button>
    <button class="portal-action" type="button">
      <span>Card</span>
      カード登録
    </button>
    <button class="portal-action" type="button">
      <span>Stay</span>
      滞在ログ
    </button>
    <button class="portal-action" type="button">
      <span>Queue</span>
      選曲実行
    </button>
  </nav>

  <section class="music-panel" id="music-panel" aria-label="楽曲検索・登録">
    <h2>楽曲検索・登録</h2>
    <% unless @spotify_env_ready %>
      <p class="muted">Spotify 検索を使うには .env に SPOTIFY_CLIENT_ID と SPOTIFY_CLIENT_SECRET を設定してください。</p>
    <% end %>

    <div class="inline-form">
      <input id="music-search-input" type="search" placeholder="曲名またはアーティスト名" autocomplete="off">
      <button id="music-search-button" type="button">検索</button>
    </div>

    <section>
      <h3>検索結果</h3>
      <div class="list-panel" id="music-search-results">
        <p class="muted">Spotify から曲を検索できます。</p>
      </div>
    </section>

    <section>
      <h3>お気に入り</h3>
      <div class="list-panel" id="favorite-tracks">
        <% if @favorite_tracks.any? %>
          <% @favorite_tracks.each do |track| %>
            <article class="track-row" data-favorite-track-id="<%= track.spotify_track_id %>">
              <% if track.image_url.present? %>
                <img src="<%= track.image_url %>" alt="">
              <% else %>
                <img alt="">
              <% end %>
              <div>
                <strong class="is-added"><%= track.track_name %></strong>
                <span><span class="track-kind"></span>楽曲・<%= track.artist_name %></span>
              </div>
              <span class="track-menu">...</span>
              <button class="track-icon-button is-added" type="button" data-remove-track="<%= track.id %>" aria-label="お気に入りから削除">✓</button>
            </article>
          <% end %>
        <% else %>
          <p class="muted">登録済みの曲はありません。</p>
        <% end %>
      </div>
    </section>
  </section>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
<script src="/3d_room.js"></script>
<script>
  const apiBase = "/api/v1";
  const musicPanel = document.getElementById("music-panel");
  const portalSidebar = document.getElementById("portal-sidebar");
  const musicSearchInput = document.getElementById("music-search-input");
  const favoriteTrackIds = new Set(
    Array.from(document.querySelectorAll("[data-favorite-track-id]")).map((element) => element.dataset.favoriteTrackId)
  );

  document.querySelector("[data-open-music]").addEventListener("click", () => {
    musicPanel.classList.add("is-open");
    portalSidebar.classList.add("is-hidden");
    musicSearchInput.focus();
  });
  document.getElementById("music-search-button").addEventListener("click", searchTracks);
  musicSearchInput.addEventListener("keydown", (event) => {
    if (event.key === "Enter") searchTracks();
  });
  bindFavoriteRemoveButtons();

  async function searchTracks() {
    const query = document.getElementById("music-search-input").value.trim();
    if (!query) return setStatus("検索語を入力してください");

    setStatus("検索中");
    const response = await fetch(`${apiBase}/spotify/search?q=${encodeURIComponent(query)}`);
    const data = await response.json();
    const container = document.getElementById("music-search-results");

    if (data.status !== "success") {
      container.innerHTML = `<p class="muted">${escapeHtml(data.message || "検索に失敗しました")}</p>`;
      setStatus("検索に失敗しました");
      return;
    }

    container.innerHTML = data.results.map((track) => `
      <article class="track-row">
        ${track.image_url ? `<img src="${escapeHtml(track.image_url)}" alt="">` : "<img alt=\"\">"}
        <div>
          <strong class="${favoriteTrackIds.has(track.spotify_track_id) ? "is-added" : ""}">${escapeHtml(track.track_name)}</strong>
          <span><span class="track-kind"></span>楽曲・${escapeHtml(track.artist_name || "")}</span>
        </div>
        <span class="track-menu">...</span>
        ${favoriteTrackIds.has(track.spotify_track_id)
          ? `<button class="track-icon-button is-added" type="button" disabled aria-label="登録済み">✓</button>`
          : `<button class="track-icon-button" type="button" data-track="${encodeURIComponent(JSON.stringify(track))}" aria-label="お気に入りに追加">＋</button>`}
      </article>
    `).join("") || `<p class="muted">該当する曲がありません。</p>`;

    container.querySelectorAll("[data-track]").forEach((button) => {
      button.addEventListener("click", () => addTrack(JSON.parse(decodeURIComponent(button.dataset.track))));
    });
    setStatus("検索完了");
  }

  async function addTrack(track) {
    const response = await fetch(`${apiBase}/spotify/tracks`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ track }),
    });
    const data = await response.json();
    setStatus(data.status === "success" ? "お気に入りに追加しました" : data.message);
    if (data.status === "success") favoriteTrackIds.add(track.spotify_track_id);
    refreshSearchResultButtons();
    loadFavoriteTracks();
  }

  async function loadFavoriteTracks() {
    const response = await fetch(`${apiBase}/spotify/tracks`);
    const data = await response.json();
    const container = document.getElementById("favorite-tracks");

    if (data.status !== "success") {
      container.innerHTML = `<p class="muted">${escapeHtml(data.message || "お気に入りを取得できませんでした")}</p>`;
      return;
    }

    container.innerHTML = data.tracks.map((track) => `
      <article class="track-row" data-favorite-track-id="${track.spotify_track_id}">
        ${track.image_url ? `<img src="${escapeHtml(track.image_url)}" alt="">` : "<img alt=\"\">"}
        <div>
          <strong class="is-added">${escapeHtml(track.track_name)}</strong>
          <span><span class="track-kind"></span>楽曲・${escapeHtml(track.artist_name)}</span>
        </div>
        <span class="track-menu">...</span>
        <button class="track-icon-button is-added" type="button" data-remove-track="${track.id}" data-remove-spotify-track-id="${track.spotify_track_id}" aria-label="お気に入りから削除">✓</button>
      </article>
    `).join("") || `<p class="muted">登録済みの曲はありません。</p>`;

    bindFavoriteRemoveButtons();
  }

  function bindFavoriteRemoveButtons() {
    document.querySelectorAll("[data-remove-track]").forEach((button) => {
      button.addEventListener("click", async () => {
        await fetch(`${apiBase}/spotify/tracks/${button.dataset.removeTrack}`, { method: "DELETE" });
        if (button.dataset.removeSpotifyTrackId) favoriteTrackIds.delete(button.dataset.removeSpotifyTrackId);
        setStatus("お気に入りから削除しました");
        loadFavoriteTracks();
      });
    });
  }

  function refreshSearchResultButtons() {
    document.querySelectorAll("[data-track]").forEach((button) => {
      const track = JSON.parse(decodeURIComponent(button.dataset.track));
      if (!favoriteTrackIds.has(track.spotify_track_id)) return;

      const row = button.closest(".track-row");
      row.querySelector("strong").classList.add("is-added");
      button.outerHTML = `<button class="track-icon-button is-added" type="button" disabled aria-label="登録済み">✓</button>`;
    });
  }

  function setStatus(message) {
    document.getElementById("room-status").textContent = message;
  }

  function escapeHtml(value) {
    const div = document.createElement("div");
    div.textContent = value || "";
    return div.innerHTML;
  }
</script>
